#!/bin/bash

requirements=(
  stow            # required for script
  fish nvim       # need latest!
  tmux git        # relatively new version needed
  fzf             # go: any version,    latest preferred
  fd rg bat delta # cargo: any version, latest preferred
)

for i in ${requirements[@]}; do
  echo command: $i
  hash $i 2>/dev/null || {
    echo "Missing command - \"$i\""
    echo "Install before continuing"
    exit 1
  }
done

exit

case $1 in
  '')
    stow -R --target="$HOME" home
    ;;
  --uninstall|-u)
    stow -D --target="$HOME" home
    ;;
  *)
    echo $"Usage: $0 [-u|--uninstall]"
    ;;
esac
